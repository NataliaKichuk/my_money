# --- INSTRUCTIONS ---
# 1. Copy this file and rename it to .env
# 2. If using SQLite, keep DB_TYPE=sqlite
# 3. If using PostgreSQL, set DB_TYPE=postgres and fill in the credentials below

# Security
SECRET_KEY=your-secret-key-here
DEBUG=True

# Database Settings (postgres or sqlite)
DB_TYPE=sqlite

# PostgreSQL Credentials (required only if DB_TYPE=postgres)
DB_NAME=my_db_name
DB_USER=my_db_user
DB_PASS=my_db_password
DB_HOST=127.0.0.1
DB_PORT=5432